
# Usually in my experience, the api domain name would change at least once a year.
# So, I am moving it to configuration. You don't have to modify this unless necessary.
DOMAIN=www.alphavantage.co

# Get the API key from here: https://www.alphavantage.co/support/#api-key
API_KEY=demo

# You have 25 requests per day for a free API key
REQUEST_RATE=25

# If you use the API_KEY=demo, then only these 2 symbols are supported
DEMO_SYMBOLS=["TSCO.LON","IBM"]

# https://www.alphavantage.co/documentation/#monthly
# This API covers 20+ years of historical data.
HISTORICAL_DEPTH=25