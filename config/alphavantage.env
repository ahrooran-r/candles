# TImeout to connect to DOMAIN. In seconds.
# As of now, I am connecting from laptop. Maybe we can reduce this when connecting from Server
CONNECT_TIMEOUT=3

# Timeout for other operations, like payload fetching etc. In seconds.
REQUEST_TIMEOUT=10